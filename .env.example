# Bot Framework 身份配置（用于 Teams 与你的机器人服务之间的鉴权）
MicrosoftAppType=MultiTenant
MicrosoftAppId=
MicrosoftAppPassword=
MicrosoftAppTenantId=

# 中国区云环境可选配置（仅在 Azure 中国区部署时启用）
# ChannelService=https://botframework.azure.cn
# OAuthUrl=https://token.botframework.azure.cn/
# ToChannelFromBotLoginUrl=https://login.partner.microsoftonline.cn/<App-Tenant-Id>
# ToChannelFromBotOAuthScope=https://api.botframework.azure.cn
# ToBotFromChannelTokenIssuer=https://api.botframework.azure.cn
# ToBotFromChannelOpenIdMetadataUrl=https://login.botframework.azure.cn/v1/.well-known/openidconfiguration
# ToBotFromEmulatorOpenIdMetadataUrl=https://login.partner.microsoftonline.cn/a55a4d5b-9241-49b1-b4ff-befa8db00269/v2.0/.well-known/openid-configuration
# ValidateAuthority=true

# Dify 接口配置
API_ENDPOINT=https://demo.dify.hk/v1/chat-messages
API_KEY=

# Dify 请求超时（毫秒）
DIFY_TIMEOUT_MS=90000

# Teams/WebChat 流式输出开关
# false: 仅最终一次性回复
# true: 增量更新同一条消息
BOT_STREAMING_ENABLED=true

# 允许启用流式的频道，逗号分隔
BOT_STREAMING_CHANNELS=msteams,webchat,directline

# 两次 updateActivity 之间的最小时间间隔（毫秒）
BOT_STREAM_UPDATE_INTERVAL_MS=1000

# 与上次已展示内容相比，最少新增多少字符才触发更新
BOT_STREAM_MIN_CHARS_DELTA=50

# 首条流式消息最少字符数（避免首条过短导致 UI 抖动）
BOT_STREAM_FIRST_MESSAGE_MIN_CHARS=10